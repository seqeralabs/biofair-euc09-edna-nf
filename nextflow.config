/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    biofair/edna Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments.
    `params` mirror the original Snakemake config/config.yaml.
*/

params {
    // -- Input / output --
    input                  = null
    outdir                 = 'results'
    publish_dir_mode       = 'copy'

    // -- fastp (Snakemake: fastp:) --
    fastp_min_length       = 50
    fastp_quality_cutoff   = 20
    adapter_fasta          = null

    // -- Host removal (Snakemake: host_removal:) --
    host_removal           = false
    host_bowtie2_index     = null

    // -- Kraken2 (Snakemake: kraken2:) --
    kraken2_db             = null
    kraken2_confidence     = 0.1

    // -- Bracken (Snakemake: bracken:) --
    bracken_read_length    = 100
    bracken_level          = 'S'
    bracken_threshold      = 10

    // -- AMR profiling (Snakemake: amr:) --
    run_amr                = true
    amr_database           = 'card'
    amr_min_identity       = 80
    amr_min_coverage       = 80

    // -- MultiQC --
    multiqc_config         = null

    // -- Generic resource ceilings (used by conf/base.config check_max) --
    max_cpus               = 16
    max_memory             = '128.GB'
    max_time               = '48.h'
}

// Load base resource configuration (process labels)
includeConfig 'conf/base.config'

// Load per-module ext.args and publishDir directives
includeConfig 'conf/modules.config'

profiles {
    debug {
        process.beforeScript = 'echo $HOSTNAME'
        cleanup              = false
    }
    docker {
        docker.enabled       = true
        docker.runOptions    = '-u $(id -u):$(id -g)'
        conda.enabled        = false
        singularity.enabled  = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled        = true
        docker.enabled       = false
        singularity.enabled  = false
    }
    wave {
        wave.enabled    = true
        wave.strategy   = 'conda,container'
    }
    test      { includeConfig 'conf/test.config'      }
    test_full { includeConfig 'conf/test.config'      }
}

// Default container registry
docker.registry      = 'quay.io'
singularity.registry = 'quay.io'

// Execution reports
timeline { enabled = true; file = "${params.outdir}/pipeline_info/execution_timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/execution_report.html";   overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/execution_trace.txt";      overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/pipeline_dag.html";        overwrite = true }

manifest {
    name            = 'biofair/edna'
    author          = 'BioFAIR EUC-09 / UK CEH'
    description     = 'eDNA & shotgun-metagenomics: QC -> classification -> AMR profiling'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// Function to enforce resource ceilings (nf-core idiom)
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) { return obj }
    }
}
