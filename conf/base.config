/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    biofair/edna base resource config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Process resource requirements via standard nf-core resource labels.
    The Snakemake `threads:` map is replaced by these labels.
*/

process {

    cpus   = { check_max( 1    * task.attempt, 'cpus'   ) }
    memory = { check_max( 6.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h  * task.attempt, 'time'   ) }

    errorStrategy = { task.exitStatus in [104,134,137,139,143,247] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // -- Resource labels (Snakemake threads: config -> nf-core labels) --
    withLabel:process_single {
        cpus   = { check_max( 1                  , 'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h  * task.attempt, 'time'   ) }
    }
    withLabel:process_low {        // fastqc (2), bracken (2)
        cpus   = { check_max( 2     * task.attempt, 'cpus'   ) }
        memory = { check_max( 8.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }
    withLabel:process_medium {     // fastp (4), amr (4)
        cpus   = { check_max( 6     * task.attempt, 'cpus'   ) }
        memory = { check_max( 36.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }
    withLabel:process_high {       // host_removal (8), kraken2 (8) -- DB held in RAM
        cpus   = { check_max( 12    * task.attempt, 'cpus'   ) }
        memory = { check_max( 72.GB * task.attempt, 'memory' ) }
        time   = { check_max( 16.h  * task.attempt, 'time'   ) }
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
