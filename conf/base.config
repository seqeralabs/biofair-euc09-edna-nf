/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    biofair/edna base resource config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Process resource requirements via standard nf-core resource labels.
    The Snakemake `threads:` map is replaced by these labels.

    Resource ceilings are enforced with the modern `resourceLimits` directive
    (Nextflow 24.04+). It caps any request — including the `* task.attempt`
    retry expressions below — to the largest available infrastructure, so we no
    longer need the legacy nf-core `check_max()` helper or `max_*` params.
    Override `process.resourceLimits` in a site-specific config / profile to
    match a particular executor (see conf/test.config for a small-runner example).
*/

process {

    // Cap every request (including the `* task.attempt` retry expressions
    // below) to the largest available infrastructure. Override
    // `process.resourceLimits` in a site / test profile to match a smaller or
    // larger environment.
    resourceLimits = [
        cpus:   16,
        memory: 128.GB,
        time:   48.h
    ]

    cpus   = { 1    * task.attempt }
    memory = { 6.GB * task.attempt }
    time   = { 4.h  * task.attempt }

    errorStrategy = { task.exitStatus in [104,134,137,139,143,247] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // -- Resource labels (Snakemake threads: config -> nf-core labels) --
    withLabel:process_single {
        cpus   = { 1               }
        memory = { 4.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_low {        // fastqc (2), bracken (2)
        cpus   = { 2     * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {     // fastp (4), amr (4)
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {       // host_removal (8), kraken2 (8) -- DB held in RAM
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
