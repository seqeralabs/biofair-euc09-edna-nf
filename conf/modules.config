/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module configuration: ext.args and publishDir
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    This is where Snakemake `params:` and `output:` (publishing) are expressed.
    Tool flags live in ext.args; output locations live in publishDir.
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: 'FASTQC' {
        ext.args   = '--quiet'
        publishDir = [ path: { "${params.outdir}/fastqc" }, mode: params.publish_dir_mode ]
    }

    withName: 'FASTP' {
        // Snakemake: --length_required, --cut_right, --cut_right_mean_quality
        ext.args   = { "--length_required ${params.fastp_min_length} --cut_right --cut_right_mean_quality ${params.fastp_quality_cutoff}" }
        publishDir = [
            path: { "${params.outdir}/trimmed" },
            mode: params.publish_dir_mode,
            pattern: "*.{json,html,log}"
        ]
    }

    withName: 'BOWTIE2_HOSTREMOVAL' {
        publishDir = [ path: { "${params.outdir}/decontam" }, mode: params.publish_dir_mode ]
    }

    withName: 'KRAKEN2' {
        // Snakemake: --confidence
        ext.args   = { "--confidence ${params.kraken2_confidence}" }
        publishDir = [ path: { "${params.outdir}/kraken2" }, mode: params.publish_dir_mode ]
    }

    withName: 'BRACKEN' {
        // Snakemake: -r read_length -l level -t threshold
        ext.args   = { "-r ${params.bracken_read_length} -l ${params.bracken_level} -t ${params.bracken_threshold}" }
        publishDir = [ path: { "${params.outdir}/bracken" }, mode: params.publish_dir_mode ]
    }

    withName: 'ABRICATE' {
        // Snakemake: --db --minid --mincov
        ext.when   = { params.run_amr }
        ext.args   = { "--db ${params.amr_database} --minid ${params.amr_min_identity} --mincov ${params.amr_min_coverage}" }
        publishDir = [ path: { "${params.outdir}/amr" }, mode: params.publish_dir_mode ]
    }

    withName: 'MULTIQC' {
        publishDir = [ path: { "${params.outdir}/multiqc" }, mode: params.publish_dir_mode ]
    }
}
