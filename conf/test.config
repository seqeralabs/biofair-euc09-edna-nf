/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for automated, minimal-input testing
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Use as: nextflow run . -profile test,docker

    Runs the pipeline FOR REAL on a tiny, public test dataset (the nf-core
    taxprofiler test set). The reads are designed to classify against the
    bundled Kraken2/Bracken test DB, so Kraken2 + Bracken produce real output.
    No `-stub` is needed or wanted here.
*/

// Small resource ceilings for CI-sized runners — caps every process request,
// overriding the base.config limits. Kraken2 loads the whole DB into RAM, so
// the memory ceiling is raised enough to hold the test database.
process {
    resourceLimits = [
        cpus:   4,
        memory: 14.GB,
        time:   6.h
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal real test dataset to check pipeline function'

    // Remote test samplesheet: one paired-end and one single-end sample.
    input      = "${projectDir}/assets/samplesheet_test.csv"

    // Kraken2 / Bracken test database as a gzipped tarball (extracted at runtime
    // by the PREPARE_KRAKEN_DB subworkflow). Contains hash.k2d, opts.k2d,
    // taxo.k2d and the database{100,150}mers.kmer_distrib Bracken k-mer tables.
    kraken2_db         = 'https://raw.githubusercontent.com/nf-core/test-datasets/taxprofiler/data/database/bracken/testdb-bracken.tar.gz'

    // Host removal and AMR profiling are out of scope for this smoke test:
    // there is no host index, and abricate is not meaningful on raw reads.
    host_removal       = false
    run_amr            = false

    // Matches database100mers in the test DB.
    bracken_read_length = 100
    bracken_level       = 'S'
    bracken_threshold   = 10
}
