/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for automated, tiny-input testing
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Use as: nextflow run . -profile test,docker -stub

    Pairs with `-stub` so processes emit empty placeholder outputs and no real
    reference databases or reads are required to exercise the DAG end-to-end.
*/

// Small resource ceilings for CI runners — caps every process request to what
// a GitHub-Actions-sized runner can provide, overriding the base.config limits.
process {
    resourceLimits = [
        cpus:   2,
        memory: 6.GB,
        time:   6.h
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Tiny bundled inputs (paths relative to the pipeline root)
    input      = "${projectDir}/assets/samplesheet.csv"

    // Placeholder reference dirs — only need to exist for the DAG when using -stub
    kraken2_db         = "${projectDir}/assets/test_db"
    host_removal       = false
    run_amr            = true
    amr_database       = 'card'

    bracken_read_length = 100
    bracken_level       = 'S'
    bracken_threshold   = 10
}
